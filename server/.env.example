# Environment Variables - Backend Server
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# MongoDB Connection String
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/stream-app?retryWrites=true&w=majority

# Port the server runs on
PORT=5000

# JWT Secret - Use a strong random string (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-very-secure-random-jwt-secret-key-minimum-32-chars

# LiveKit Credentials
# Get from LiveKit Cloud: https://cloud.livekit.io
LIVEKIT_URL=https://your-instance.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-api-secret-key

# CORS & Client Configuration
# Should match your frontend URL
CLIENT_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Notes:
# - Keep this file secret, never commit to git
# - Different values for dev/production environments
# - Use strong random values for JWT_SECRET
# - LiveKit credentials from cloud.livekit.io
